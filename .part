		<section id="stack" class="relative py-24 border-y border-border/50 bg-card/30">
			<div class="container mx-auto max-w-7xl px-6">
				<div class="grid lg:grid-cols-2 gap-12 items-center">
					<div><span
							class="inline-flex items-center gap-2 text-xs uppercase tracking-widest text-primary"><svg
